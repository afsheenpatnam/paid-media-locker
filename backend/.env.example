# Copy this file to .env and fill in real values before running the server.

# Postgres connection string. For local docker-compose the default below matches docker-compose.yml.
DATABASE_URL="postgresql://locker:lockerpass@localhost:5432/paid_media_locker?schema=public"

# Server
PORT=4000
NODE_ENV=development

# JWT
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Signed URL (original file access) HMAC secret + token lifetime in seconds
SIGNED_URL_SECRET="change-me-to-another-long-random-string"
SIGNED_URL_TTL_SECONDS=90

# New user starting wallet balance
STARTING_WALLET_BALANCE=100

# Local storage roots (never served statically)
STORAGE_ORIGINALS_DIR="./storage/originals"
STORAGE_PREVIEWS_DIR="./storage/previews"

# Demo account seeded by `npm run seed`
DEMO_EMAIL="demo@lockerapp.test"
DEMO_PASSWORD="Demo@1234"
