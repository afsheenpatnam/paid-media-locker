# Copy to .env and point at your backend.
# Local dev (Android emulator reaching your host machine): http://10.0.2.2:4000
# Physical device on same Wi-Fi as your dev machine: http://<your-lan-ip>:4000
# Production / APK build: the deployed Render URL, e.g. https://paid-media-locker-backend.onrender.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:4000
